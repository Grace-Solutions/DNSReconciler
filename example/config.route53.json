{
    "settings": {
        "runtime": {
            "schedule":          "0 0 */4 * * *",
            "jitter":            "auto",
            "timezone":          "UTC",
            "cleanupOnShutdown":        true,
            "logLevel":                 "Information",
            "dryRun":                   false
        },
        "network": {
            "addressSources": [
                { "priority": 1, "type": "publicIPv4",  "enabled": true },
                { "priority": 2, "type": "cgnatIPv4",   "enabled": true },
                { "priority": 3, "type": "rfc1918IPv4", "enabled": true }
            ]
        }
    },

    "providers": [
        {
            "providerId":      "d8aed64f-7c2a-4929-98d4-946fc7b1c26d",
            "friendlyName":    "route53-primary",
            "type":            "route53",
            "enabled":         true,
            "accessKeyId":     "env:AWS_ACCESS_KEY_ID",
            "secretAccessKey": "env:AWS_SECRET_ACCESS_KEY",
            "hostedZoneId":    "env:AWS_HOSTED_ZONE_ID",
            "region":          "us-east-1",
            "zone":            "example.com",
            "ttl":             300,
            "comment":         "{'hostname': '${HOSTNAME}', 'nodeId': '${NODE_ID}'}"
        }
    ],

    "records": [
        {
            "providerId": "d8aed64f-7c2a-4929-98d4-946fc7b1c26d",
            "recordId":   "e670a3b9-2e56-486e-a7f2-31d4069d218e",
            "enabled":    true,
            "type":       "A",
            "name":       "${HOSTNAME}.${ZONE}",
            "content":    "${SELECTED_IPV4}"
        },
        {
            "providerId": "d8aed64f-7c2a-4929-98d4-946fc7b1c26d",
            "recordId":   "5f934aa1-8999-4174-81ba-4599d6e706b7",
            "enabled":    false,
            "type":       "AAAA",
            "name":       "${HOSTNAME}.${ZONE}",
            "content":    "${SELECTED_IPV6}"
        }
    ],

    "containerRecords": [
        {
            "description": "Creates DNS records for containers configured with MACVLAN or IPVLAN networking",
            "providerId":  "d8aed64f-7c2a-4929-98d4-946fc7b1c26d",
            "enabled":     true,
            "type":        "A",
            "name":        "${LABEL:dns.hostname}.${ZONE}",
            "content":     "${CONTAINER_IP}",
            "comment":     "{'containerName':'${CONTAINER_NAME}','hostname':'${HOSTNAME}','nodeId':'${NODE_ID}'}",
            "include":     [".*"],
            "exclude":     ["^$"],
            "matchFields": ["auto"]
        }
    ]
}
