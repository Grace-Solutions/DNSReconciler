{
    "settings": {
        "runtime": {
            "reconcileIntervalSeconds": 120,
            "cleanupOnShutdown":        true,
            "logLevel":                 "Information",
            "dryRun":                   false
        },
        "network": {
            "addressSources": [
                { "priority": 1, "type": "publicIPv4",  "enabled": true },
                { "priority": 2, "type": "cgnatIPv4",   "enabled": true },
                { "priority": 3, "type": "rfc1918IPv4", "enabled": true }
            ]
        }
    },

    "providers": [
        {
            "providerId":   "18212128-4239-40a8-bc79-6a990f254be0",
            "friendlyName": "cloudflare-primary",
            "type":         "cloudflare",
            "enabled":      true,
            "apiToken":     "env:CF_API_TOKEN",
            "zoneId":       "env:CF_ZONE_ID",
            "baseUrl":      "https://api.cloudflare.com/client/v4",
            "zone":         "example.com",
            "ttl":          120,
            "proxied":      false,
            "comment":      "{'hostname': '${HOSTNAME}', 'nodeId': '${NODE_ID}'}",
            "tags": [
                { "name": "managed-by", "value": "dnsreconciler" },
                { "name": "node-id",    "value": "${NODE_ID}" }
            ]
        }
    ],

    "records": [
        {
            "providerId": "18212128-4239-40a8-bc79-6a990f254be0",
            "recordId":   "d40a7f8d-f3a0-499e-842e-f066dc6bf874",
            "enabled":    true,
            "type":       "A",
            "name":       "${HOSTNAME}.${ZONE}",
            "content":    "${SELECTED_IPV4}"
        },
        {
            "providerId": "18212128-4239-40a8-bc79-6a990f254be0",
            "recordId":   "2da921f6-3e5d-4215-9373-5d685820f2e8",
            "enabled":    false,
            "type":       "AAAA",
            "name":       "${HOSTNAME}.${ZONE}",
            "content":    "${SELECTED_IPV6}"
        }
    ],

    "containerRecords": [
        {
            "_comment":    "Creates A records for containers on MACVLAN networks using the dns.hostname label",
            "providerId":  "18212128-4239-40a8-bc79-6a990f254be0",
            "templateId":  "macvlan-service-record",
            "enabled":     true,
            "type":        "A",
            "name":        "${LABEL:dns.hostname}.${ZONE}",
            "content":     "${CONTAINER_IP}",
            "comment":     "{'containerName':'${CONTAINER_NAME}','hostname':'${HOSTNAME}','nodeId':'${NODE_ID}'}",
            "tags": [
                { "name": "service", "value": "${LABEL:dns.hostname}" }
            ]
        }
    ]
}
