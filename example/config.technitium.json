{
    "settings": {
        "runtime": {
            "schedule":          "0 0 */4 * * *",
            "jitter":            "auto",
            "timezone":          "UTC",
            "cleanupOnShutdown":        true,
            "logLevel":                 "Information",
            "dryRun":                   false,
            "remote": {
                "ttl": "1h"
            }
        },
        "network": {
            "addressSources": [
                { "priority": 1, "type": "publicIPv4",  "enabled": true },
                { "priority": 2, "type": "cgnatIPv4",   "enabled": true },
                { "priority": 3, "type": "rfc1918IPv4", "enabled": true }
            ]
        }
    },

    "providers": [
        {
            "providerId":   "568111aa-1ac8-46da-8493-1a1648521ac8",
            "friendlyName": "technitium-local",
            "type":         "technitium",
            "enabled":      true,
            "apiToken":     "env:TECH_API_TOKEN",
            "baseUrl":      "env:TECH_BASE_URL",
            "zone":         "internal.example.local",
            "ttl":          120,
            "comment":      "{'hostname': '${HOSTNAME}', 'nodeId': '${NODE_ID}'}"
        }
    ],

    "records": [
        {
            "providerId": "568111aa-1ac8-46da-8493-1a1648521ac8",
            "recordId":   "7d7e5d6d-a381-484a-a68c-23b2fdf645e4",
            "enabled":    true,
            "type":       "A",
            "name":       "${HOSTNAME}.${ZONE}",
            "content":    "${SELECTED_IPV4}"
        },
        {
            "providerId": "568111aa-1ac8-46da-8493-1a1648521ac8",
            "recordId":   "f9f7076a-3210-4f63-9a68-27da8e7f021e",
            "enabled":    false,
            "type":       "AAAA",
            "name":       "${HOSTNAME}.${ZONE}",
            "content":    "${SELECTED_IPV6}"
        }
    ],

    "containerRecords": [
        {
            "description": "Creates DNS records for containers configured with MACVLAN or IPVLAN networking",
            "providerId":  "568111aa-1ac8-46da-8493-1a1648521ac8",
            "enabled":     true,
            "type":        "A",
            "name":        "${CONTAINER_NAME}.${ZONE}",
            "content":     "${CONTAINER_IP}",
            "comment":     "{'containerName':'${CONTAINER_NAME}','hostname':'${HOSTNAME}','nodeId':'${NODE_ID}'}",
            "include":     [".*"],
            "exclude":     ["^$"],
            "matchFields": ["auto"]
        }
    ]
}
