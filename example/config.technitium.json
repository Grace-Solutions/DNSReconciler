            "addressSources": [
                { "priority": 1, "type": "publicIPv4",  "enabled": true },
                { "priority": 2, "type": "cgnatIPv4",   "enabled": true },
                { "priority": 3, "type": "rfc1918IPv4", "enabled": true }
            ]
        }
    },

    "providers": [
        {
