{
    "settings": {
        "runtime": {
            "reconcileIntervalSeconds": 120,
            "cleanupOnShutdown":        true,
            "logLevel":                 "Information",
            "dryRun":                   false
        },
        "network": {
            "addressSources": [
                { "priority": 1, "type": "publicIPv4",  "enabled": true },
                { "priority": 2, "type": "cgnatIPv4",   "enabled": true },
                { "priority": 3, "type": "rfc1918IPv4", "enabled": true }
            ]
        }
    },

    "providers": [
        {
            "id":           "c0b2e442-2045-448b-bfc1-a6524932d90d",
            "friendlyName": "powerdns-mesh",
            "type":         "powerdns",
            "enabled":      true,
            "apiKey":       "env:PDNS_API_KEY",
            "baseUrl":      "env:PDNS_BASE_URL",
            "serverId":     "localhost",
            "zone":         "mesh.example.internal",
            "ttl":          120,
            "comment":      "Managed by dnsreconciler on ${HOSTNAME}"
        }
    ],

    "records": [
        {
            "providerId": "powerdns-mesh",
            "recordId":   "050ef75c-5acb-48b0-83ed-8f9086ab81cf",
            "enabled":    true,
            "type":       "A",
            "name":       "${HOSTNAME}.mesh.example.internal",
            "content":    "${SELECTED_IPV4}"
        },
        {
            "providerId": "powerdns-mesh",
            "recordId":   "0471d858-d257-4451-8a88-a1b73d880586",
            "enabled":    false,
            "type":       "AAAA",
            "name":       "${HOSTNAME}.mesh.example.internal",
            "content":    "${SELECTED_IPV6}"
        }
    ]
}
