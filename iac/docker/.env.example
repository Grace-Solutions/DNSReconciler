# -------------------------------------------------------
# DNS Reconciler - Provider Credentials
# Copy this file and fill in your real values.
# These are injected as environment variables into the
# container and resolved via the "env:VAR" syntax in
# config.json (§27.2).
# -------------------------------------------------------

# -- Cloudflare --
CF_API_TOKEN=
CF_ZONE_ID=

# -- Technitium --
TECH_API_TOKEN=
TECH_BASE_URL=http://technitium:5380

# -- PowerDNS --
PDNS_API_KEY=
PDNS_BASE_URL=http://powerdns:8081

