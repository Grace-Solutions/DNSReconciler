# -------------------------------------------------------
# DNS Reconciler - Docker Environment
# Copy this file to .env and fill in your real values.
#
# SECRETS: API tokens and keys are managed via Docker
# secrets (see secrets/ directory). Place each credential
# in its own file under secrets/ — they are mounted
# read-only at /run/secrets/<name> inside the container.
#
# NON-SECRET environment variables are set here and
# resolved via the "env:VAR" syntax in config.json.
# -------------------------------------------------------

# -- Container user/group IDs --
# Set these to match the host user that owns the
# mounted config/state directories.
PUID=1000
PGID=1000

# -- Reconcile interval (optional, overrides config.json) --
# RECONCILE_INTERVAL_SECONDS=120

# -- Technitium base URL (not a secret) --
TECH_BASE_URL=http://technitium:5380

# -- PowerDNS base URL (not a secret) --
PDNS_BASE_URL=http://powerdns:8081
