# -------------------------------------------------------
# DNS Reconciler — Docker Environment
#
# Copy this file to .env and fill in your real values.
# All variables here are loaded by docker compose via
# env_file: and resolved in config.json using "env:VAR".
#
# For enhanced security, use Docker secrets instead —
# see the commented-out secrets block in docker-compose.yml
# and reference them as "file:/run/secrets/<name>".
#
# Container user/group IDs — set to match the host user
# that owns the mounted config/ and state/ directories.
#
# Schedule uses 6-field cron (with seconds).
# Default: every 4 hours — 0 0 */4 * * *
#
# Application settings — every CLI flag has an env var:
#   CONFIG_PATH     — path to config.json (default: /config/config.json)
#   STATE_PATH      — override state file path
#   NODE_ID         — explicit node identity
#   ONCE            — "true" or "1" for single reconciliation pass
#   CONFIG_METHOD   — HTTP method for remote config: GET (default) or POST
#
# Remote config (optional) — fetch config from a URL
# instead of (or in addition to) local config.json.
# CONFIG_TTL controls how often to re-check (default 1h).
# -------------------------------------------------------

PUID=1000
PGID=1000

# CONFIG_PATH=/config/config.json
# STATE_PATH=
# NODE_ID=
# ONCE=false
RECONCILE_SCHEDULE=0 0 */4 * * *
# CONFIG_URL=
# CONFIG_HEADER=
# CONFIG_TOKEN=
# CONFIG_METHOD=GET
# CONFIG_TTL=1h

# Cloudflare
CF_API_TOKEN=
CF_ZONE_ID=

# Technitium
TECH_API_TOKEN=
TECH_BASE_URL=http://technitium:5380

# PowerDNS
PDNS_API_KEY=
PDNS_BASE_URL=http://powerdns:8081

# AWS Route53
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1

# Azure DNS
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=
# AZURE_SUBSCRIPTION_ID=
