{
    "version": 1,

    "providerDefaults": {
        "azure": {
            "tenantId":        "env:AZURE_TENANT_ID",
            "clientId":        "env:AZURE_CLIENT_ID",
            "clientSecret":    "env:AZURE_CLIENT_SECRET",
            "subscriptionId":  "env:AZURE_SUBSCRIPTION_ID",
            "resourceGroup":   "env:AZURE_RESOURCE_GROUP",
            "zoneName":        "env:AZURE_ZONE_NAME"
        }
    },

    "runtime": {
        "reconcileIntervalSeconds": 120,
        "cleanupOnShutdown":        true,
        "logLevel":                 "Information",
        "dryRun":                   false
    },

    "network": {
        "addressSources": [
            { "priority": 1, "type": "publicIPv4",  "enabled": true },
            { "priority": 2, "type": "cgnatIPv4",   "enabled": true },
            { "priority": 3, "type": "rfc1918IPv4",  "enabled": true }
        ]
    },

    "defaults": {
        "enabled":   true,
        "ownership": "perNode",
        "ttl":       300,
        "proxied":   false,
        "tags": [
            { "name": "managed-by",  "value": "dnsreconciler" },
            { "name": "node-id",     "value": "${NODE_ID}" }
        ]
    },

    "records": [
        {
            "id":       "azure-host-v4",
            "enabled":  true,
            "provider": "azure",
            "zone":     "example.com",
            "type":     "A",
            "name":     "${HOSTNAME}.example.com",
            "content":  "${SELECTED_IPV4}"
        },
        {
            "id":       "azure-host-v6",
            "enabled":  false,
            "provider": "azure",
            "zone":     "example.com",
            "type":     "AAAA",
            "name":     "${HOSTNAME}.example.com",
            "content":  "${SELECTED_IPV6}"
        }
    ]
}

